// the order will be (according to the SIGGRAPH paper, Algorithm 1):
// predictPositions (apply forces) -> updateNeighbourGrid ->
// calculateDensityAndLambda -> applyVorticity
#define PI 3.14159265359f
#pragma kernel clearNeighbourGrid
#pragma kernel buildNeighbourGrid
#pragma kernel calculateSomething
#pragma kernel predictPositions
#pragma kernel calculateDensityAndLambda
#pragma kernel applyDensityConstraints
#pragma kernel calculateVorticity
#pragma kernel updateParticles

struct Particle {
  float2 position;
  float2 velocity;
};

struct Hash {
  uint hash; // Particle hash (z-curve ordering)
  uint pid;  // Particle index
};

struct GPUObstacleAABB {
    float2 minPos;
    float2 maxPos;
};

// Storing Particle positions and velocity
RWStructuredBuffer<Particle> Particles;

// Grid cell for neighbour search
RWStructuredBuffer<uint> ParticlesInCell;
RWStructuredBuffer<uint> NInCell;
RWStructuredBuffer<float> LambdaBuffer;
RWStructuredBuffer<float> Vorticity;

// temporary buffer to store the predicted positions (x*) from the solver
RWStructuredBuffer<float2> PredictedPositionsBuffer;

// SDF Buffers
RWStructuredBuffer<float> SdfValuesBuffer;
RWStructuredBuffer<float2> SdfGradientBuffer;

// Debug color buffer
RWStructuredBuffer<float4> Colors;

// interaction buffers
StructuredBuffer<GPUObstacleAABB> ObstaclesBuffer;
RWStructuredBuffer<uint> CollisionFeedbackBuffer;

// PBF simulation parameters, coming from the C#

cbuffer SimulationSettings {
  uint ParticleCount;
  uint GridCellCount;
  uint MaxParticlesPerCell;
  float cellSize;
  float
      dt; // fixed deltaTime to avoid instabilities, do NOT send Time.deltaTime
  float smoothingRadius;
  float2 gravity;
  float vorticity_epsilon;
  float viscosity_c;
  float collision_damping;
  float rho_0;
  uint ObstacleCount;
  int sdfResolution;
  float2 sdfSize;
};

